</nav>

<section id="inicio" class="hero-overlay relative min-h-screen w-full flex flex-col items-center justify-center overflow-hidden text-center text-white px-6">
    <div class="relative z-10 max-w-[800px]">
        <h1 class="text-[40px] md:text-[56px] font-extrabold mb-6 leading-tight tracking-tight">El motor agrícola de tu negocio, directo del campo</h1>
        <p class="text-[18px] md:text-[20px] text-gray-300 mb-10 leading-relaxed max-w-2xl mx-auto">Conectamos productores locales con comercios, hoteles y restaurantes en Venezuela. Suministro al por mayor sin intermediarios.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="login" class="bg-brand_lime text-navy_dark px-10 py-4 rounded-full font-bold btn-pill text-lg">Comenzar Ahora</a>
            <a href="#servicios" class="border-2 border-brand_lime text-brand_lime px-10 py-4 rounded-full font-bold hover:bg-brand_lime/10 transition text-lg">Explorar Beneficios</a>
        </div>
    </div>
</section>

