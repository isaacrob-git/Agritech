<script>
    const nav = document.getElementById('mainNav');
    const navTitle = document.getElementById('navTitle');
    const btnLogin = document.getElementById('btnLogin');
    const navLinks = document.querySelectorAll('#navLinks a:not(.bg-brand_lime):not(#btnLogin)');

    window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
            nav.classList.add('bg-white', 'backdrop-blur-md', 'shadow-md');
            navTitle.style.color = '#102A32'; 
            btnLogin.style.color = '#102A32';
            btnLogin.style.borderColor = 'rgba(16, 42, 50, 0.2)';
            navLinks.forEach(link => { link.style.color = '#102A32'; });
        } else {
            nav.classList.remove('bg-white', 'backdrop-blur-md', 'shadow-md');
            navTitle.style.color = '#FFFFFF';
            btnLogin.style.color = '#FFFFFF';
            btnLogin.style.borderColor = 'rgba(255, 255, 255, 0.3)';
            navLinks.forEach(link => { link.style.color = 'rgba(255, 255, 255, 0.9)'; });
        }
    });
</script>

