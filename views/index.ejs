<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AgriTech C.A. | Cosecha Directa</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand_lime: '#D1F09B',
                        brand_lime_dark: '#B8E07D',
                        navy_dark: '#102A32',
                        navy_deep: '#0A1F26',
                        off_white: '#F4F4F2',
                        neutral_text: '#526268'
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    borderRadius: {
                        'button': '24px',
                        'card': '20px',
                        'section': '24px'
                    }
                }
            }
        }
    </script>

    <style>
        /* CSS INTEGRADO */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { width: 100%; overflow-x: hidden; }

        .hero-overlay {
            width: 100%; height: 100vh;
            display: flex; align-items: center; justify-content: center;
            background: linear-gradient(rgba(10, 31, 38, 0.75), rgba(10, 31, 38, 0.85)), 
                        url('img/fondo5.jpg');
            background-size: cover; background-position: center;
        }

        .btn-pill { transition: all 0.3s ease; }
        .btn-pill:hover { transform: translateY(-2px) scale(1.02); }

        #mainNav { transition: all 0.4s ease; }
        #btnLogin:hover { background: rgba(209, 240, 155, 0.1); }

        /* EFECTO DE FUSIÓN PARA LA IMAGEN DEL STORE */
        .store-image-container {
            position: relative;
            width: 100%;
            height: 100%;
            background: url('img/fondo6.jpg'); /* Asegúrate de tener esta imagen */
            background-size: cover;
            background-position: center;
        }

        /* Degradado para fundir la imagen con el fondo navy_dark */
        .store-fusion-mask {
            position: absolute;
            inset: 0;
            background: linear-gradient(to right, #102A32 0%, transparent 20%, transparent 80%, #102A32 100%),
                        linear-gradient(to top, #102A32 0%, transparent 15%);
        }

        @media (max-width: 1024px) {
            .store-fusion-mask {
                background: linear-gradient(to bottom, #102A32 0%, transparent 20%, transparent 80%, #102A32 100%);
            }
        }
    </style>
</head>
<body class="bg-white text-navy_dark font-sans">

<nav id="mainNav" class="fixed top-0 w-full z-50 transition-all duration-300 px-6 h-16 flex items-center">
    <div class="max-w-[1200px] mx-auto w-full flex justify-between items-center">
        <a href="#" class="text-xl font-extrabold tracking-tighter flex items-center gap-2" id="navLogo">
            <div class="w-6 h-6 bg-brand_lime rounded-sm"></div>
            <span class="text-white transition-colors duration-300" id="navTitle">Cosecha Directa</span>
        </a>
        
        <div class="hidden md:flex items-center gap-6 text-[14px] font-semibold" id="navLinks">
            <div class="flex gap-6 mr-4">
