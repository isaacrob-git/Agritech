                <a href="#nosotros" class="text-white/90 hover:text-brand_lime transition">Nosotros</a>
                <a href="#servicios" class="text-white/90 hover:text-brand_lime transition">Beneficios</a>
            </div>
            
            <div class="flex items-center gap-3">
